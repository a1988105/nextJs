# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Auth
# Use AUTH_SECRET going forward. NEXTAUTH_SECRET is still supported as a
# fallback for compatibility, but you only need to set one of them.
# Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ---------------------------------------------------------------------------
AUTH_SECRET=replace-with-a-long-random-secret
# NEXTAUTH_SECRET=replace-with-a-long-random-secret

# ---------------------------------------------------------------------------
# CoinGecko API
# Free tier base URL  : https://api.coingecko.com/api/v3
# Paid tier base URL  : https://pro-api.coingecko.com/api/v3
# ---------------------------------------------------------------------------
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
# COINGECKO_API_KEY=
